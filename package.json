{
  "name": "youtube-watch-party-server",
  "version": "1.0.0",
  "private": true,
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "migrate:up": "node ./node_modules/knex/bin/cli.js migrate:latest",
    "migrate:down": "node ./node_modules/knex/bin/cli.js migrate:rollback"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.18.3",
    "knex": "^3.1.0",
    "socket.io": "^4.7.5",
    "sqlite3": "^5.1.7"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.30",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.3"
  }
}
